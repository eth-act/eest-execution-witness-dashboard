new file mode 100644
--- /dev/null
+++ b/src/utils/publicAssets.ts
@@ -0,0 +1,7 @@
+export const publicAssetPath = (path: string) => {
+  const base = import.meta.env.BASE_URL.endsWith('/')
+    ? import.meta.env.BASE_URL
+    : `${import.meta.env.BASE_URL}/`;
+
+  return `${base}${path.replace(/^\/+/, '')}`;
+};
